{
	"name": "svelte-local-query",
	"version": "0.1.0",
	"description": "SvelteKit remote functions API (query, command, form) for local, client-only use \u2014 no backend required.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/touchifyapp/svelte-local-query.git"
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"remote-functions",
		"query",
		"command",
		"form",
		"spa",
		"runes"
	],
	"type": "module",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": false,
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-package && publint",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"peerDependencies": {
		"svelte": "^5.29.0"
	},
	"dependencies": {
		"@standard-schema/spec": "^1.1.0",
		"esm-env": "^1.2.2"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/node": "^26.1.1",
		"jsdom": "^29.1.1",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"publint": "^0.3.21",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"typescript": "^6.0.3",
		"valibot": "^1.4.2",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	}
}
